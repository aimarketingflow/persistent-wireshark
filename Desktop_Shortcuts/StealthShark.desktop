[Desktop Entry]
Version=1.0
Type=Application
Name=StealthShark Anti-Pineapple
Comment=Advanced WiFi security tool to detect and block pineapple attacks
Exec=/Users/flowgirl/Documents/StealthShark-PublicRelease/launch.sh
Icon=/Users/flowgirl/Documents/StealthShark-PublicRelease/Desktop_Shortcuts/stealthshark-icon.png
Path=/Users/flowgirl/Documents/StealthShark-PublicRelease
Terminal=true
Categories=Network;Security;System;
Keywords=wifi;security;pineapple;detection;network;
StartupNotify=true
MimeType=text/csv;
Actions=ImportCSV;ManageBlacklist;

[Desktop Action ImportCSV]
Name=Import CSV Threats
Exec=/Users/flowgirl/Documents/StealthShark-PublicRelease/launch.sh --import-csv

[Desktop Action ManageBlacklist]
Name=Manage Blacklist
Exec=/Users/flowgirl/Documents/StealthShark-PublicRelease/launch.sh --manage-blacklist
