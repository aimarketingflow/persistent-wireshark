# LoopbackShark .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
*venv/
*_venv/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# LoopbackShark specific
analysis_results/*.json
analysis_results/*.md
pcap_captures/*.pcap
pcap_captures/*.pcapng
persistent_logs/*.log
gui_logs/*.log
test_capture/*.pcap
test_capture/*.pcapng

# Settings (may contain user paths)
loopbackshark_settings.json

# Temporary files
*.tmp
*.temp
*.log

# Large files
*.gz
*.zip
*.tar
*.tar.gz
*.tar.bz2
